<?xml version="1.0" encoding="utf-8"?>
<!--
  UR5e URDF — PHILOS Project
  Based on Universal Robots UR5e official specifications.
  DH parameters and link dimensions from the UR5e datasheet.

  This URDF defines the kinematic chain and physical properties
  used for both simulation physics AND the 3D digital twin visualization.
  Any change here automatically propagates to both systems.

  Mounting: Fixed pedestal (no AMR in initial setup).
  Payload: beaker + liquid ≈ 0.55 kg (well within 5 kg limit).
-->
<robot name="ur5e">

  <!-- ════════════════════════════════════════════════════════════════════
       WORLD & PEDESTAL (fixed mount — replaces AMR in initial setup)
       ════════════════════════════════════════════════════════════════════ -->

  <link name="world"/>

  <link name="pedestal">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.70"/>
      </geometry>
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
      <material name="pedestal_grey">
        <color rgba="0.25 0.28 0.32 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.70"/>
      </geometry>
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
      <inertia ixx="0.82" ixy="0" ixz="0" iyy="0.82" iyz="0" izz="0.064"/>
    </inertial>
  </link>

  <joint name="pedestal_fixed" type="fixed">
    <parent link="world"/>
    <child link="pedestal"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════
       UR5e KINEMATIC CHAIN
       DH parameters (modified):
         a  = [0,     -0.425, -0.3922, 0,      0,      0     ]
         d  = [0.1625, 0,      0,      0.1333, 0.0997, 0.0996]
         α  = [π/2,    0,      0,      π/2,   -π/2,    0     ]
       ════════════════════════════════════════════════════════════════════ -->

  <!-- ── BASE LINK ─────────────────────────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.060" length="0.050"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="ur_dark">
        <color rgba="0.15 0.15 0.20 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.060" length="0.050"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.0061" ixy="0" ixz="0" iyy="0.0061" iyz="0" izz="0.0072"/>
    </inertial>
  </link>

  <joint name="base_fixed" type="fixed">
    <parent link="pedestal"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.70" rpy="0 0 0"/>
  </joint>

  <!-- ── SHOULDER (Link 0 → Link 1) ───────────────────────────────────── -->
  <link name="shoulder_link">
    <visual>
      <geometry>
        <cylinder radius="0.055" length="0.1625"/>
      </geometry>
      <origin xyz="0 0 0.08125" rpy="0 0 0"/>
      <material name="ur_blue">
        <color rgba="0.0 0.4 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.055" length="0.1625"/>
      </geometry>
      <origin xyz="0 0 0.08125" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="3.7"/>
      <origin xyz="0 0 0.08125" rpy="0 0 0"/>
      <inertia ixx="0.0102" ixy="0" ixz="0" iyy="0.0102" iyz="0" izz="0.0056"/>
    </inertial>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.050" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" velocity="2.0944" effort="150.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── UPPER ARM (Link 1 → Link 2) ──────────────────────────────────── -->
  <link name="upper_arm_link">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.425"/>
      </geometry>
      <origin xyz="0 0 0.2125" rpy="0 0 0"/>
      <material name="ur_blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.425"/>
      </geometry>
      <origin xyz="0 0 0.2125" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="8.393"/>
      <origin xyz="0 0 0.2125" rpy="0 0 0"/>
      <inertia ixx="0.1338" ixy="0" ixz="0" iyy="0.1338" iyz="0" izz="0.0085"/>
    </inertial>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.1625" rpy="0 1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" velocity="2.0944" effort="150.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── FOREARM (Link 2 → Link 3) ─────────────────────────────────────── -->
  <link name="forearm_link">
    <visual>
      <geometry>
        <cylinder radius="0.038" length="0.3922"/>
      </geometry>
      <origin xyz="0 0 0.1961" rpy="0 0 0"/>
      <material name="ur_light_blue">
        <color rgba="0.2 0.6 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.038" length="0.3922"/>
      </geometry>
      <origin xyz="0 0 0.1961" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.275"/>
      <origin xyz="0 0 0.1961" rpy="0 0 0"/>
      <inertia ixx="0.0311" ixy="0" ixz="0" iyy="0.0311" iyz="0" izz="0.0016"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.425" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" velocity="3.1416" effort="150.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── WRIST 1 (Link 3 → Link 4) ─────────────────────────────────────── -->
  <link name="wrist_1_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.1333"/>
      </geometry>
      <origin xyz="0 0 0.06665" rpy="0 0 0"/>
      <material name="ur_dark"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.1333"/>
      </geometry>
      <origin xyz="0 0 0.06665" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.219"/>
      <origin xyz="0 0 0.06665" rpy="0 0 0"/>
      <inertia ixx="0.0025" ixy="0" ixz="0" iyy="0.0025" iyz="0" izz="0.0007"/>
    </inertial>
  </link>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="0 0 0.3922" rpy="0 1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" velocity="3.4907" effort="28.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ── WRIST 2 (Link 4 → Link 5) ─────────────────────────────────────── -->
  <link name="wrist_2_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.0997"/>
      </geometry>
      <origin xyz="0 0 0.04985" rpy="0 0 0"/>
      <material name="ur_dark"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.0997"/>
      </geometry>
      <origin xyz="0 0 0.04985" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.219"/>
      <origin xyz="0 0 0.04985" rpy="0 0 0"/>
      <inertia ixx="0.0014" ixy="0" ixz="0" iyy="0.0014" iyz="0" izz="0.0007"/>
    </inertial>
  </link>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 0 0.1333" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" velocity="3.4907" effort="28.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ── WRIST 3 / TOOL FLANGE (Link 5 → Link 6) ──────────────────────── -->
  <link name="wrist_3_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.0996"/>
      </geometry>
      <origin xyz="0 0 0.0498" rpy="0 0 0"/>
      <material name="ur_accent">
        <color rgba="0.5 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.0996"/>
      </geometry>
      <origin xyz="0 0 0.0498" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1879"/>
      <origin xyz="0 0 0.0498" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0 0.0997" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" velocity="3.4907" effort="28.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ── TOOL FLANGE (end-effector mounting point) ─────────────────────── -->
  <link name="tool0">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.010"/>
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <material name="ur_accent"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
    </inertial>
  </link>

  <joint name="tool_fixed" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.0996" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════
       PARALLEL-JAW GRIPPER (Robotiq 2F-85 inspired)
       
       Simplified parallel gripper with two prismatic finger joints.
       Each finger slides linearly to open/close.  Both fingers are
       controlled by a single "gripper" action in the policy.
       
       The beaker is NOT part of the URDF — it is a free object on the
       lab bench that the robot must approach, grasp, lift, and pour.
       ════════════════════════════════════════════════════════════════════ -->

  <!-- Gripper housing / body -->
  <link name="gripper_body">
    <visual>
      <geometry>
        <box size="0.085 0.055 0.040"/>
      </geometry>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <material name="gripper_dark">
        <color rgba="0.50 0.54 0.62 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.085 0.055 0.040"/>
      </geometry>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.68"/>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="gripper_body_fixed" type="fixed">
    <parent link="tool0"/>
    <child link="gripper_body"/>
    <origin xyz="0 0 0.005" rpy="0 0 0"/>
  </joint>

  <!-- Gripper coupling / top plate (where fingers mount) -->
  <link name="gripper_coupler">
    <visual>
      <geometry>
        <box size="0.070 0.040 0.008"/>
      </geometry>
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <material name="gripper_mid">
        <color rgba="0.45 0.48 0.56 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="gripper_coupler_fixed" type="fixed">
    <parent link="gripper_body"/>
    <child link="gripper_coupler"/>
    <origin xyz="0 0 0.040" rpy="0 0 0"/>
  </joint>

  <!-- ── LEFT FINGER (prismatic, slides in −X to open) ─────────────── -->
  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.012 0.022 0.060"/>
      </geometry>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <material name="finger_grey">
        <color rgba="0.58 0.60 0.68 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.012 0.022 0.060"/>
      </geometry>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_coupler"/>
    <child link="left_finger"/>
    <origin xyz="-0.008 0 0.008" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.040" velocity="0.5" effort="20.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Left finger rubber pad -->
  <link name="left_finger_pad">
    <visual>
      <geometry>
        <box size="0.010 0.020 0.018"/>
      </geometry>
      <origin xyz="0.005 0 0.009" rpy="0 0 0"/>
      <material name="pad_rubber">
        <color rgba="0.25 0.25 0.30 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0.005 0 0.009" rpy="0 0 0"/>
      <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
    </inertial>
  </link>

  <joint name="left_pad_fixed" type="fixed">
    <parent link="left_finger"/>
    <child link="left_finger_pad"/>
    <origin xyz="0 0 0.060" rpy="0 0 0"/>
  </joint>

  <!-- ── RIGHT FINGER (prismatic, slides in +X to open) ────────────── -->
  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.012 0.022 0.060"/>
      </geometry>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <material name="finger_grey">
        <color rgba="0.58 0.60 0.68 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.012 0.022 0.060"/>
      </geometry>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_coupler"/>
    <child link="right_finger"/>
    <origin xyz="0.008 0 0.008" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.040" velocity="0.5" effort="20.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Right finger rubber pad -->
  <link name="right_finger_pad">
    <visual>
      <geometry>
        <box size="0.010 0.020 0.018"/>
      </geometry>
      <origin xyz="-0.005 0 0.009" rpy="0 0 0"/>
      <material name="pad_rubber">
        <color rgba="0.25 0.25 0.30 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="-0.005 0 0.009" rpy="0 0 0"/>
      <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
    </inertial>
  </link>

  <joint name="right_pad_fixed" type="fixed">
    <parent link="right_finger"/>
    <child link="right_finger_pad"/>
    <origin xyz="0 0 0.060" rpy="0 0 0"/>
  </joint>

  <!-- ── GRIPPER TIP (reference point at finger tips center) ───────── -->
  <link name="gripper_tip">
    <visual>
      <geometry>
        <sphere radius="0.004"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="tip_glow">
        <color rgba="0.7 0.3 1.0 0.9"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
    </inertial>
  </link>

  <joint name="gripper_tip_fixed" type="fixed">
    <parent link="gripper_coupler"/>
    <child link="gripper_tip"/>
    <origin xyz="0 0 0.078" rpy="0 0 0"/>
  </joint>

</robot>
